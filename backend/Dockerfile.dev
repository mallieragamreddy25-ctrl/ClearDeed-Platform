# Development stage with hot reload
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev dependencies for nodemon & ts-node)
RUN npm ci

# Copy source code
COPY src ./src
COPY tsconfig.json ./
COPY .env.development ./.env

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/v1/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})" || exit 1

# Start development server with hot reload
CMD ["npm", "run", "dev"]
